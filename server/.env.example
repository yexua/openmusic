PORT=4000

# 空房销毁、音乐 API、七牛和接口盒子均可在管理后台修改。
# 下面对应的环境变量仅作为首次启动或尚未保存后台配置时的默认值。

# 房间无人后自动销毁时间（毫秒）
# 默认：10分钟。比如想更久可改成 3600000（1小时）。
# 设置为 0 则无人立即销毁（慎用）。
ROOM_EMPTY_TTL_MS=600000

# 服务重启后，仍有内容（队列/当前曲/历史/聊天/成员）的房间不会因重启被解散，
# 而是保留等待用户重连。此项为额外的重启宽限期（毫秒）：
# 默认 0 = 一直保留，交由正常“无人离开”流程按 ROOM_EMPTY_TTL_MS 清理；
# 设为 >0（如 86400000 表示 24 小时）则重启后超过该宽限期仍无人重连才清理。
ROOM_RESTART_GRACE_MS=0

# 生产环境必填：允许访问的前端 Origin，多个用英文逗号分隔（必须 https）
CLIENT_URL=https://your-domain.com

# 生产环境必填：用于签名浏览器会话 ID，重启后保持用户身份连续
CLIENT_ID_SECRET=replace_with_a_long_random_secret

# API 请求签名校验（生产默认开启；本地调试可设 API_SIGN_REQUIRED=0 关闭）
# API_SIGN_REQUIRED=1
# 部署模式：production（默认，安全限制完整）或 test（允许 HTTP 测试访问）
DEPLOYMENT_MODE=production
# 以下为旧版细粒度兼容项；新部署优先使用 DEPLOYMENT_MODE
# ALLOW_INSECURE_HTTP_API=0
# ALLOW_INSECURE_COOKIES=0
# API_SIGN_WINDOW_SEC=300
# 媒体流（/api/meting、/api/media-proxy）签名有效期（秒）；代码强制不少于 1200=20 分钟
# API_MEDIA_SIGN_WINDOW_SEC=1200

# 会话 Cookie / HMAC 有效期（秒），默认 7776000 = 90 天；临近过期时 bootstrap 会静默续签
# SESSION_TTL_SEC=7776000

# 宝塔/Nginx 反代后务必开启：安全限流信任回源头
TRUST_PROXY=1

# 管理后台由首次部署 Web 向导创建，账号密码哈希只存 Redis，不写此文件。
# 默认首次登录：admin / 123456；登录后强制修改账号密码。

# 使用 CDN 时必填：回源真实客户端 IP 头名（优先于 X-Real-IP / X-Forwarded-For）
# Cloudflare: CF-Connecting-IP
# EdgeOne: iqp
# CLIENT_IP_HEADER=CF-Connecting-IP


# Meting API（网易云 + QQ 播放/歌词/封面/歌单导入）
# 支持英文逗号分隔多个上游做负载均衡（轮询 + 故障 60s 冷却自动切换）：
# METING_API_URL=http://10.0.0.1:3000,http://10.0.0.2:3000
# 支持混入 ChKSz API（https://api.chksz.com，自动识别；其他部署地址加 chksz: 前缀）：
# 该上游承接网易云 + QQ 音乐的搜索/播放/歌词/封面（网易云另支持歌单导入）；
# FM 漫游等不支持的请求自动交给其他上游
# METING_API_URL=http://10.0.0.1:3000,chksz:https://your-chksz.example.com

METING_API_URL=http://localhost:3000

# 多上游时同样用逗号分隔、与 URL 一一对应；只填一个则应用到所有上游
METING_API_AUTH=your_apikey_here

# 上游健康主动探测间隔（毫秒）；默认 60000，冷却中的上游每周期探测以便快速恢复，
# 健康上游每 5 个周期抽检一次。设 0 关闭探测。
# METING_HEALTH_PROBE_INTERVAL_MS=60000



# 迟言 API（酷狗搜索/播放、图片审核等）

CYAPI_BASE=https://cyapi.top/API

CYAPI_KEY=your_apikey_here



# 歌词备用（按歌名）

VMY_LRC_URL=https://api.52vmy.cn/api/music/lrc

# LrcAPI 歌词兜底（https://docs.lrc.cx，按 标题+歌手+专辑 匹配，优先于上面的按歌名兜底）
# 默认使用公共实例；可改为自部署地址；支持英文逗号分隔多个地址做负载均衡
# （轮询 + 故障 60s 冷却自动切换）；置空 LRCAPI_URL= 则禁用该级兜底
# 也可在管理后台「运行时配置 → 歌词备用」中修改，无需重启
# LRCAPI_URL=https://api.lrc.cx
# LRCAPI_URL=https://api.lrc.cx,https://your-self-hosted-lrcapi.example.com



# Redis（必需）：房间、收藏、管理凭据、站点公告、封禁与审计均只存 Redis，无内存兜底。
# 首次部署也可在 Web 安装向导里填写；未配置时服务仅允许进入 /setup。

# 方式一：连接串（适合无账号或密码已写在 URL 里）
# REDIS_URL=redis://127.0.0.1:6379/0

# 方式二：分项配置（账号密码没有就不填）
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DB=0

# 七牛云 OSS（聊天图片，可选；不配置则无法发送图片）

# QINIU_ACCESS_KEY=

# QINIU_SECRET_KEY=

# QINIU_BUCKET=

# QINIU_DOMAIN=https://cdn.example.com

# 存储区域：z0 华东 | z1 华北 | z2 华南 | na0 北美 | as0 东南亚

# QINIU_ZONE=z0

# 接口盒子（可选；表情包搜索、聊天敏感词检测共用）
# APIHZ_BASE_URL=https://cn.apihz.cn/api
# APIHZ_ID=
# APIHZ_KEY=
# 兼容旧配置名（与 APIHZ_ID / APIHZ_KEY 二选一即可）
# APIHZ_IMG_ID=
# APIHZ_IMG_KEY=

