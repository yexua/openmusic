{
  "name": "openmusic",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "typecheck": "npm run typecheck --prefix client",
    "build:check": "npm run build:check --prefix client",
    "start": "npm run start --prefix server",
    "package:build": "node scripts/package-build.mjs",
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "cap:sync:android": "npm run cap:sync:android --prefix client",
    "cap:sync:ios": "npm run cap:sync:ios --prefix client",
    "cap:open:android": "npm run cap:open:android --prefix client",
    "cap:open:ios": "npm run cap:open:ios --prefix client",
    "cap:run:android": "npm run cap:run:android --prefix client",
    "cap:run:ios": "npm run cap:run:ios --prefix client",
    "cap:build:apk": "npm run cap:build:apk --prefix client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20 <25"
  }
}
